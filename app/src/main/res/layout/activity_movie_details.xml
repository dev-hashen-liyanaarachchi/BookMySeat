<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBackDetails"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFC107" />

        <!-- Movie Poster -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <ImageView
                android:id="@+id/ivPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_movie_placeholder" />
        </androidx.cardview.widget.CardView>

        <!-- Event Title -->
        <TextView
            android:id="@+id/txtDetailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Event Title"
            android:textColor="#FFC107"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Movie Name -->
        <TextView
            android:id="@+id/txtMovieTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Movie: Avatar 2"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- Description -->
        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Description"
            android:textColor="#BBBBBB"
            android:textSize="14sp" />

        <!-- Date -->
        <TextView
            android:id="@+id/txtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Date: 2024-03-20"
            android:textColor="#FFC107"
            android:textSize="14sp" />

        <!-- Time -->
        <TextView
            android:id="@+id/txtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Time: 14:30"
            android:textColor="#FFC107"
            android:textSize="14sp" />

        <!-- Venue -->
        <TextView
            android:id="@+id/txtVenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Venue: Colombo"
            android:textColor="#FFC107"
            android:textSize="14sp" />

        <!-- Location (Google Maps) -->
        <TextView
            android:id="@+id/txtLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="📍 Location"
            android:textColor="#888888"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Contact Number -->
        <TextView
            android:id="@+id/txtContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="📞 Contact"
            android:textColor="#888888"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Open Map Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenMap"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="🗺️ Maps"
                android:textAllCaps="false"
                android:textColor="#FFC107"
                app:backgroundTint="#1A1A1A"
                app:cornerRadius="24dp"
                app:strokeColor="#FFC107"
                app:strokeWidth="1dp"
                android:visibility="gone" />

            <!-- Call Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCall"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                android:layout_weight="1"
                android:text="📞 Call"
                android:textAllCaps="false"
                android:textColor="#FFC107"
                app:backgroundTint="#1A1A1A"
                app:cornerRadius="24dp"
                app:strokeColor="#FFC107"
                app:strokeWidth="1dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Price -->
        <TextView
            android:id="@+id/txtPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Price: LKR 1200 per seat"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Book Now Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBookNow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="Book Now"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FFC107"
            app:cornerRadius="28dp" />

        <View android:layout_width="match_parent" android:layout_height="20dp" />

    </LinearLayout>
</ScrollView>